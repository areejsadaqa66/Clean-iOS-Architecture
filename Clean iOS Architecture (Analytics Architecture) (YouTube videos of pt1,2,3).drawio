        <mxCell id="cmp-n1" parent="1" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;" value="&lt;b&gt;Why Composition Root is the best approach:&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;• Main is the ONLY layer that knows about ALL modules - nothing knows about Main&lt;/div&gt;&lt;div&gt;• Adapters are ~5 LOC each, protecting the system from 3rd party SDK changes&lt;/div&gt;&lt;div&gt;• LoginPresenter (~15 LOC) translates UseCase output into UI protocol calls&lt;/div&gt;&lt;div&gt;• LoginUseCase (~20 LOC) is pure business logic with zero framework imports&lt;/div&gt;&lt;div&gt;• Login VC (~40 LOC) depends ONLY on LoginView protocol, fully platform-agnostic&lt;/div&gt;&lt;div&gt;• ComposeLoginUseCaseDelegate implements LoginUseCaseOutput and composes all behaviours&lt;/div&gt;&lt;div&gt;• Open/Closed: add new analytics by adding a new wrapper adapter, never modifying existing code&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="640" x="5200" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="cmp-n2" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=12;fillColor=#fffacd;strokeColor=#d6b656;" value="&lt;b&gt;Dependency Rule:&lt;/b&gt;&lt;div&gt;Dependencies point INWARD only&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Main knows: all modules&lt;/div&gt;&lt;div&gt;UI knows: protocols only&lt;/div&gt;&lt;div&gt;Presentation knows: protocols only&lt;/div&gt;&lt;div&gt;Analytics knows: 3rd party SDKs&lt;/div&gt;&lt;div&gt;Business Logic knows: nothing about outer layers&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Inner layers are STABLE. Outer layers change.&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="380" x="5900" y="1220" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
